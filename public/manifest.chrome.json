{
    "name": "Keep Tabs",
    "description": "Tool to manage your browser workspace.",
    "homepage_url": "https://github.com/cenirevec/keeptabs",
    "version": "0.5.1.7",
    "manifest_version": 3,
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "icons": {
        "48": "media/ico.png"
    },
    "action": {
        "default_icon": "media/ico.png"
    },
    "permissions": [
        "tabs",
        "storage",
        "unlimitedStorage"
    ]
}