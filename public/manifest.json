{
  "name": "Keep Tabs",
  "description": "Tool to manage your browser workspace.",
  "homepage_url": "https://github.com/cenirevec/keeptabs",
  "version": "0.5.2",
  "manifest_version": 3,
  "background": {
    "scripts": [
      "engine.js"
    ]
  },
  "icons": {
    "48": "media/ico.png"
  },
  "action": {
    "default_icon": "media/ico.png"
  },
  "permissions": [
    "tabs",
    "storage",
    "unlimitedStorage"
  ]
}